# {{ istota_namespace | capitalize }} secrets - managed by Ansible
# Loaded via EnvironmentFile= in systemd service.
#
# Naming convention: ISTOTA_<SECTION>_<FIELD>, matching the config dataclass
# path (e.g. developer.gitlab_token → ISTOTA_DEVELOPER_GITLAB_TOKEN). Same
# convention as docker-compose env vars; the config loader's override map
# in config.py reads these literal names. Each instance has its own
# EnvironmentFile (per-namespace path), so there's no cross-instance
# env collision risk.
{% if istota_nextcloud_app_password %}
ISTOTA_NEXTCLOUD_APP_PASSWORD={{ istota_nextcloud_app_password }}
{% endif %}
{% if istota_email_imap_password %}
ISTOTA_EMAIL_IMAP_PASSWORD={{ istota_email_imap_password }}
{% endif %}
{% if istota_email_smtp_password | default(istota_email_imap_password) %}
ISTOTA_EMAIL_SMTP_PASSWORD={{ istota_email_smtp_password | default(istota_email_imap_password) }}
{% endif %}
{% if istota_developer_gitlab_token %}
ISTOTA_DEVELOPER_GITLAB_TOKEN={{ istota_developer_gitlab_token }}
{% endif %}
{% if istota_developer_github_token %}
ISTOTA_DEVELOPER_GITHUB_TOKEN={{ istota_developer_github_token }}
{% endif %}
{% if istota_web_oauth2_client_secret %}
ISTOTA_WEB_OAUTH2_CLIENT_SECRET={{ istota_web_oauth2_client_secret }}
{% endif %}
{% if istota_web_secret_key %}
ISTOTA_WEB_SESSION_SECRET_KEY={{ istota_web_secret_key }}
{% endif %}
{% if istota_google_workspace_client_secret %}
ISTOTA_GOOGLE_WORKSPACE_CLIENT_SECRET={{ istota_google_workspace_client_secret }}
{% endif %}
{% if istota_claude_code_oauth_token %}
CLAUDE_CODE_OAUTH_TOKEN={{ istota_claude_code_oauth_token }}
{% endif %}
{% if istota_secret_key %}
ISTOTA_SECRET_KEY={{ istota_secret_key }}
{% endif %}
{% if istota_brain_native_api_key %}
# Native-brain provider key (brain.native.api_key) — read two levels deep by the
# config loader. Per-user keys are in the encrypted secrets table instead.
ISTOTA_BRAIN_NATIVE_API_KEY={{ istota_brain_native_api_key }}
{% endif %}
