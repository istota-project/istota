# {{ user_id }} - managed by Ansible

display_name = "{{ user_config.display_name | default(user_id) }}"
{% if user_config.email_addresses is defined and user_config.email_addresses %}
email_addresses = {{ user_config.email_addresses | to_json }}
{% endif %}
timezone = "{{ user_config.timezone | default('UTC') }}"
{% if user_config.log_channel is defined and user_config.log_channel %}
log_channel = "{{ user_config.log_channel }}"
{% endif %}
{% if user_config.alerts_channel is defined and user_config.alerts_channel %}
alerts_channel = "{{ user_config.alerts_channel }}"
{% endif %}
{% if user_config.trusted_email_senders is defined and user_config.trusted_email_senders %}
trusted_email_senders = {{ user_config.trusted_email_senders | to_json }}
{% endif %}
{% if user_config.ntfy_topic is defined and user_config.ntfy_topic %}
ntfy_topic = "{{ user_config.ntfy_topic }}"
{% endif %}
{% if user_config.site_enabled is defined and user_config.site_enabled %}
site_enabled = true
{% endif %}
{% if user_config.max_foreground_workers is defined %}
max_foreground_workers = {{ user_config.max_foreground_workers }}
{% endif %}
{% if user_config.max_background_workers is defined %}
max_background_workers = {{ user_config.max_background_workers }}
{% endif %}
{% if user_config.disabled_skills is defined and user_config.disabled_skills %}
disabled_skills = {{ user_config.disabled_skills | to_json }}
{% endif %}
{# Phase 7a: [[resources]] blocks moved to the user_resources DB table.
   Provisioning happens via `istota resource ensure` (see main.yml). The
   `reminders_file` shortcut now goes through the same path — operators can
   either set `reminders_file` in istota_users (which the playbook converts
   to a resource ensure call) or declare a `[[resources]] type =
   reminders_file` entry directly.

   Phase 7b: [[briefings]] blocks moved to the briefing_configs DB table.
   Provisioning happens via `istota briefing ensure` (see main.yml). The
   per-user TOML file now contains only profile fields (kept here as a
   fallback for the config loader; the DB row wins). The deploy template
   task is itself a candidate for removal once all live deploys have
   migrated. #}
