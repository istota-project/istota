# {{ istota_namespace | capitalize }} — {{ istota_hostname }}
# Managed by Ansible — do not edit manually

# Redirect HTTP to HTTPS
server {
  listen [::]:80;
  listen 80;
  server_name {{ istota_hostname }};

  # include /etc/nginx/snippets/letsencrypt.conf;

  location / {
    return 301 https://$host$request_uri;
  }
}

server {
  listen [::]:443 ssl;
  listen 443 ssl;
  http2 on;

  server_name {{ istota_hostname }};

  # Default SSL certificates (comment out after Let's Encrypt enabled)
  include /etc/nginx/snippets/snakeoil.conf;

  # Uncomment block after Let's Encrypt cert is generated
  # ssl_certificate /etc/letsencrypt/live/{{ istota_hostname }}/fullchain.pem;
  # ssl_certificate_key /etc/letsencrypt/live/{{ istota_hostname }}/privkey.pem;
  # ssl_trusted_certificate /etc/letsencrypt/live/{{ istota_hostname }}/chain.pem;

  charset utf-8;

  # Prevent search engine indexing by default
  add_header X-Robots-Tag "noindex, nofollow" always;

  # include /etc/nginx/snippets/letsencrypt.conf;

{% if istota_site_enabled %}
  # The bot's own static web root
  root {{ istota_home }}/html;
  autoindex on;
{% endif %}

{% if istota_web_enabled %}
  # Task event SSE stream — must stream, not buffer. Longest-prefix match wins
  # over /istota/, so this block handles the streaming chat endpoints. The web
  # app also sets `X-Accel-Buffering: no`, but HTTP/1.1 + a long read timeout
  # are needed here so a long idle gap between events doesn't drop the stream.
  location /istota/api/chat/ {
    proxy_pass http://127.0.0.1:{{ istota_web_port }}/istota/api/chat/;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 3600s;
  }

  location /istota/ {
    proxy_pass http://127.0.0.1:{{ istota_web_port }}/istota/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Money is served by istota's web service at /istota/money/* — no separate
  # backend or nginx include needed.
{% endif %}

{% if istota_location_enabled %}
  location /webhooks/ {
    proxy_pass http://127.0.0.1:{{ istota_webhooks_port }}/webhooks/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    client_max_body_size 10m;
  }
{% endif %}
}
