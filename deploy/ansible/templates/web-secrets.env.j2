# {{ istota_namespace | capitalize }} web-only secrets - managed by Ansible.
#
# Loaded via EnvironmentFile= by the *web* unit ONLY. The scheduler and
# webhooks units must never see this file: ISTOTA_WEB_TOKEN_KEY decrypts the
# user-scoped Nextcloud OAuth pairs in web_user_tokens, and keeping it out of
# every other process is the custody boundary the feature is built on
# (see the user-scoped-nextcloud-oauth-talk-sync spec).
ISTOTA_WEB_TOKEN_KEY={{ istota_web_token_key }}
