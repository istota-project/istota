# {{ istota_namespace | capitalize }} configuration - managed by Ansible

# Install namespace (drives /etc/{namespace}/, secrets paths, etc.)
namespace = "{{ istota_namespace }}"

# Bot identity
bot_name = "{{ istota_bot_name | default(istota_namespace | capitalize, true) }}"
emissaries_enabled = {{ istota_emissaries_enabled | lower }}
{% if istota_model %}
model = "{{ istota_model }}"
{% endif %}
{% if istota_effort %}
effort = "{{ istota_effort }}"
{% endif %}
{% if istota_custom_system_prompt %}
custom_system_prompt = true
{% endif %}

# Database path. Filename is fixed (technical IDs are always istota); only
# the parent dir is per-deploy via {{ istota_home }}.
db_path = "{{ istota_home }}/data/istota.db"

# Local-disk root for per-user module DBs (feeds/health/location/money). Local
# disk, NOT the Nextcloud mount: WAL's -shm SIGBUSes on the FUSE mount. Only the
# .db lives here; user-facing module files stay in the workspace on the mount.
module_data_dir = "{{ istota_module_data_dir }}"

# File access configuration
{% if istota_use_nextcloud_mount %}
# Nextcloud mount path (direct filesystem access)
nextcloud_mount_path = "{{ istota_nextcloud_mount_path }}"
{% endif %}
# rclone remote name for Nextcloud files (used when mount_path not set, or for owner detection)
rclone_remote = "{{ istota_rclone_remote }}"

# Path to skills directory (individual skill files loaded selectively)
# Points to src/config/skills where skills and guidelines folders live in the repo
skills_dir = "{{ istota_repo_dir }}/config/skills"
{% if istota_disabled_skills %}
disabled_skills = {{ istota_disabled_skills | to_json }}
{% endif %}

# Temporary directory
temp_dir = "{{ istota_home }}/tmp"

# Experimental feature flags — operator opt-in for rough features that
# ship in the tree but are off by default. See docs/EXPERIMENTAL.md for
# the registry. Override via `istota_experimental_features` in
# host_vars / group_vars. Example: ["money_tax", "money_wash_sales"].
[experimental]
features = {{ istota_experimental_features | to_json }}

[brain]
# Which model-invocation backend the executor uses.
#   "claude_code" (default) wraps the headless `claude -p` CLI subprocess.
#   "native"                runs istota's own in-process agent loop.
#   "tmux_claude"           drives the interactive `claude` TUI via tmux
#                           (needs tmux on the host).
# Operator runbook: docs/configuration/native-brain.md.
kind = "{{ istota_brain_kind | default('claude_code', true) }}"
{% if istota_brain_kind == 'native' or istota_brain_source_type_overrides %}

[brain.native]
# Used when kind = "native" or a source_type_overrides entry routes to native.
# The API key stays out of this file — see ISTOTA_BRAIN_NATIVE_API_KEY in the
# EnvironmentFile.
provider = "{{ istota_brain_native_provider | default('openai_compat', true) }}"
{% if istota_brain_native_model %}
model = "{{ istota_brain_native_model }}"
{% endif %}
{% if istota_brain_native_effort %}
effort = "{{ istota_brain_native_effort }}"
{% endif %}
base_url = "{{ istota_brain_native_base_url | default('https://api.anthropic.com/v1', true) }}"
context_window = {{ istota_brain_native_context_window | default(0, true) }}
max_turns = {{ istota_brain_native_max_turns | default(100, true) }}
max_tokens = {{ istota_brain_native_max_tokens | default(16384, true) }}
{# prompt_caching: "" (default) → omit so the code derives it from base_url
   (on for Anthropic). Emit when the operator forced a value — accepts a YAML
   boolean or a "true"/"false" string (e.g. passed via -e on the CLI, which
   arrives as a string and would otherwise be silently dropped). #}
{% if istota_brain_native_prompt_caching is boolean %}
prompt_caching = {{ istota_brain_native_prompt_caching | lower }}
{% elif (istota_brain_native_prompt_caching | string | trim | lower) in ["true", "false"] %}
prompt_caching = {{ istota_brain_native_prompt_caching | string | trim | lower }}
{% endif %}
{% if not istota_use_environment_file and istota_brain_native_api_key %}
api_key = "{{ istota_brain_native_api_key }}"
{% endif %}
{% if istota_brain_native_extra_headers %}

[brain.native.extra_headers]
{% for header, value in istota_brain_native_extra_headers.items() %}
"{{ header }}" = "{{ value }}"
{% endfor %}
{% endif %}
{% endif %}
{% set _tmux_routed = istota_brain_source_type_overrides.values() | select('equalto', 'tmux_claude') | list | length > 0 %}
{% if istota_brain_kind == 'tmux_claude' or _tmux_routed %}

[brain.tmux]
# Used when kind = "tmux_claude" (or a source_type_overrides entry routes to it).
# All fields default in code to the prototype's pinned values; emit only the
# operability knobs here. Marker lists stay in code unless a CLI reword needs a
# hotfix (set istota_brain_tmux_ready_markers etc. then).
fallback_trip_threshold = {{ istota_brain_tmux_fallback_trip_threshold | default(5, true) }}
fallback_cooldown_seconds = {{ istota_brain_tmux_fallback_cooldown_seconds | default(300, true) }}
ready_timeout_seconds = {{ istota_brain_tmux_ready_timeout_seconds | default(30, true) }}
tmux_command_timeout = {{ istota_brain_tmux_command_timeout | default(10, true) }}
cli_version_pin = "{{ istota_brain_tmux_cli_version_pin | default('2.1.168', true) }}"
{% if istota_brain_tmux_ready_markers %}
ready_markers = {{ istota_brain_tmux_ready_markers | to_json }}
{% endif %}
{% if istota_brain_tmux_trust_markers %}
trust_markers = {{ istota_brain_tmux_trust_markers | to_json }}
{% endif %}
{% if istota_brain_tmux_theme_markers %}
theme_markers = {{ istota_brain_tmux_theme_markers | to_json }}
{% endif %}
{% if istota_brain_tmux_error_markers %}
error_markers = {{ istota_brain_tmux_error_markers | to_json }}
{% endif %}
{% if istota_brain_tmux_bypass_warning_marker %}
bypass_warning_marker = "{{ istota_brain_tmux_bypass_warning_marker }}"
{% endif %}
{% if istota_brain_tmux_bypass_accept_marker %}
bypass_accept_marker = "{{ istota_brain_tmux_bypass_accept_marker }}"
{% endif %}
{% endif %}
{% if istota_brain_source_type_overrides %}

[brain.source_type_overrides]
{% for source_type, kind in istota_brain_source_type_overrides.items() %}
{{ source_type }} = "{{ kind }}"
{% endfor %}
{% endif %}

[security]
sandbox_enabled = {{ istota_security_sandbox_enabled | lower }}
sandbox_admin_db_write = {{ istota_security_sandbox_admin_db_write | lower }}
skill_proxy_enabled = {{ istota_security_skill_proxy_enabled | lower }}
skill_proxy_timeout = {{ istota_security_skill_proxy_timeout }}
{% if istota_security_sandbox_ro_paths %}
sandbox_ro_paths = {{ istota_security_sandbox_ro_paths | to_json }}
{% endif %}

[security.network]
enabled = {{ istota_security_network_enabled | lower }}
allow_pypi = {{ istota_security_network_allow_pypi | lower }}
{% if istota_security_network_extra_hosts %}
extra_hosts = {{ istota_security_network_extra_hosts | to_json }}
{% endif %}

[nextcloud]
url = "{{ istota_nextcloud_url }}"
username = "{{ istota_nextcloud_username }}"
{% if not istota_use_environment_file %}
app_password = "{{ istota_nextcloud_app_password }}"
{% endif %}

[talk]
enabled = {{ istota_talk_enabled | lower }}
bot_username = "{{ istota_talk_bot_username }}"

[email]
enabled = {{ istota_email_enabled | lower }}
{% if istota_email_enabled %}
imap_host = "{{ istota_email_imap_host }}"
imap_port = {{ istota_email_imap_port }}
imap_user = "{{ istota_email_imap_user }}"
{% if not istota_use_environment_file %}
imap_password = "{{ istota_email_imap_password }}"
{% endif %}
smtp_host = "{{ istota_email_smtp_host }}"
smtp_port = {{ istota_email_smtp_port }}
poll_folder = "{{ istota_email_poll_folder }}"
bot_email = "{{ istota_email_bot_address }}"
{% endif %}

{# Role aliases (fast/general/smart) → concrete model ids. The native brain has
   no built-in role table, so for a native deploy default all three to the
   configured model, each optionally overridable. istota_models_roles then
   overlays (operator-explicit wins, and can add custom roles). #}
{% set _roles = {} %}
{% if istota_brain_kind == 'native' and istota_brain_native_model %}
{% set _ = _roles.update({'fast': istota_brain_native_model_fast | default('', true) or istota_brain_native_model}) %}
{% set _ = _roles.update({'general': istota_brain_native_model_general | default('', true) or istota_brain_native_model}) %}
{% set _ = _roles.update({'smart': istota_brain_native_model_smart | default('', true) or istota_brain_native_model}) %}
{% endif %}
{% if istota_models_roles %}
{% set _ = _roles.update(istota_models_roles) %}
{% endif %}
{% if _roles %}
[models.roles]
{% for role, target in _roles.items() %}
{{ role }} = "{{ target }}"
{% endfor %}

{% endif %}
[conversation]
enabled = {{ istota_conversation_enabled | lower }}
lookback_count = {{ istota_conversation_lookback_count }}
selection_model = "{{ istota_conversation_selection_model }}"
selection_timeout = {{ istota_conversation_selection_timeout }}
skip_selection_threshold = {{ istota_conversation_skip_selection_threshold }}
use_selection = {{ istota_conversation_use_selection | lower }}
always_include_recent = {{ istota_conversation_always_include_recent }}
context_truncation = {{ istota_conversation_context_truncation }}
context_recency_hours = {{ istota_conversation_context_recency_hours }}
context_min_messages = {{ istota_conversation_context_min_messages }}
previous_tasks_count = {{ istota_conversation_previous_tasks_count }}
talk_context_limit = {{ istota_conversation_talk_context_limit }}

