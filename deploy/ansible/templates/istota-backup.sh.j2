#!/bin/bash
# {{ istota_namespace | capitalize }} backup script - managed by Ansible
set -euo pipefail

DB="{{ istota_home }}/data/istota.db"
LOCAL_DIR="{{ istota_backup_local_dir }}"
REMOTE_DIR="{{ istota_backup_remote_dir }}"
MOUNT_PATH="{{ istota_nextcloud_mount_path }}"
DAILY_RETENTION={{ istota_backup_db_daily_retention }}
WEEKLY_RETENTION={{ istota_backup_db_weekly_retention }}

RCLONE_CONFIG="{{ istota_backup_rclone_config }}"
RCLONE_REMOTE="{{ istota_backup_rclone_remote }}"
RCLONE_BACKUP_PATH="{{ istota_backup_rclone_remote_path }}"

# Module DBs live per-user at {mount}/Users/<user>/<bot_dir>/<module>/data/<module>.db
# and need WAL-aware backups too — rclone file-copy is not WAL-safe.
MODULE_NAMES=(feeds money location health)

TIMESTAMP=$(date +%Y-%m-%d_%H%M%S)
DAY_OF_WEEK=$(date +%u)

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

mount_available() {
    mountpoint -q "$MOUNT_PATH" 2>/dev/null
}

# Optional failure-alert hook. Operator wires a command via
# istota_backup_alert_command; empty (the default) = no-op. The command runs
# with the alert text in $ISTOTA_BACKUP_ALERT_MESSAGE (avoids shell-quoting
# the message). Never affects the backup's own exit status.
ALERT_COMMAND="{{ istota_backup_alert_command | default('') }}"
_alert() {
    [ -n "$ALERT_COMMAND" ] || return 0
    ISTOTA_BACKUP_ALERT_MESSAGE="$1" bash -c "$ALERT_COMMAND" \
        || log "WARNING: backup alert command failed"
}

# Backup a single SQLite DB with WAL-aware .backup, integrity check, gzip,
# remote copy, and per-prefix retention rotation.
#   $1 — source DB path
#   $2 — backup name prefix (used in filename + rotation glob)
_backup_one_db() {
    local src_db="$1"
    local prefix="$2"

    if [ ! -f "$src_db" ]; then
        log "Skipping ${prefix}: source DB not found at ${src_db}"
        return 0
    fi

    log "Backing up ${prefix} (${src_db})"

    local tmp_file
    if ! tmp_file=$(mktemp "${LOCAL_DIR}/${prefix}-backup-XXXXXX.db"); then
        log "ERROR: mktemp failed for ${prefix}"
        return 1
    fi
    # Explicit cleanup on every path out. Each risky step below is handled
    # explicitly (never left to abort the shell under set -e), so the temp is
    # always removed and a failing DB can neither orphan its temp nor abort the
    # run. (A RETURN trap is avoided on purpose: it is not scope-local, so it
    # would re-fire on the caller's return and trip set -u on the out-of-scope
    # $tmp_file.)

    if ! sqlite3 "$src_db" ".backup '$tmp_file'"; then
        log "ERROR: sqlite3 .backup failed for ${prefix} (source ${src_db})"
        rm -f "$tmp_file"
        return 1
    fi

    local check
    if ! check=$(sqlite3 "$tmp_file" "PRAGMA integrity_check;" 2>&1); then
        log "ERROR: integrity check errored for ${prefix}: ${check}"
        rm -f "$tmp_file"
        return 1
    fi
    if [ "$check" != "ok" ]; then
        log "ERROR: Backup integrity check failed for ${prefix}: $check"
        rm -f "$tmp_file"
        return 1
    fi

    local backup_name="${prefix}-${TIMESTAMP}.db.gz"

    if ! gzip -c "$tmp_file" > "${LOCAL_DIR}/daily/${backup_name}"; then
        log "ERROR: gzip failed for ${prefix}"
        rm -f "${LOCAL_DIR}/daily/${backup_name}" "$tmp_file"
        return 1
    fi
    # The gzip'd daily file is now the source of truth; the raw temp is done.
    rm -f "$tmp_file"
    log "Local daily backup saved: ${LOCAL_DIR}/daily/${backup_name}"

    # Weekly + remote copies are best-effort: a failure here is logged but does
    # not fail the DB (the authoritative local daily artifact already exists).
    if [ "$DAY_OF_WEEK" -eq 7 ]; then
        cp "${LOCAL_DIR}/daily/${backup_name}" "${LOCAL_DIR}/weekly/${backup_name}" \
            && log "Local weekly backup saved: ${LOCAL_DIR}/weekly/${backup_name}" \
            || log "WARNING: local weekly copy failed for ${prefix}"
    fi

    if mount_available; then
        cp "${LOCAL_DIR}/daily/${backup_name}" "${REMOTE_DIR}/db/daily/${backup_name}" \
            && log "Remote daily backup copied: ${backup_name}" \
            || log "WARNING: remote daily copy failed for ${prefix}"

        if [ "$DAY_OF_WEEK" -eq 7 ]; then
            cp "${LOCAL_DIR}/weekly/${backup_name}" "${REMOTE_DIR}/db/weekly/${backup_name}" \
                && log "Remote weekly backup copied: ${backup_name}" \
                || log "WARNING: remote weekly copy failed for ${prefix}"
        fi
    else
        log "WARNING: Nextcloud mount not available, skipping remote copy for ${prefix}"
    fi

    # Rotate per-prefix so each (user, module) has its own retention window
    find "${LOCAL_DIR}/daily" -name "${prefix}-*.db.gz" -mtime +${DAILY_RETENTION} -delete 2>/dev/null || true
    find "${LOCAL_DIR}/weekly" -name "${prefix}-*.db.gz" -mtime +$((WEEKLY_RETENTION * 7)) -delete 2>/dev/null || true

    if mount_available; then
        find "${REMOTE_DIR}/db/daily" -name "${prefix}-*.db.gz" -mtime +${DAILY_RETENTION} -delete 2>/dev/null || true
        find "${REMOTE_DIR}/db/weekly" -name "${prefix}-*.db.gz" -mtime +$((WEEKLY_RETENTION * 7)) -delete 2>/dev/null || true
    fi

    return 0
}

# Discover per-user module DBs by scanning {mount}/Users/<user>/*/<module>/data/<module>.db.
# The bot_dir name is wildcarded so the discovery doesn't depend on namespace
# config matching the deployed mount layout.
_discover_module_dbs() {
    if ! mount_available; then
        return 0
    fi
    local users_root="${MOUNT_PATH}/Users"
    [ -d "$users_root" ] || return 0

    local module
    local find_args=()
    for module in "${MODULE_NAMES[@]}"; do
        find_args+=(-o -path "*/${module}/data/${module}.db")
    done
    # Drop the leading -o
    find_args=("${find_args[@]:1}")

    find "$users_root" -mindepth 5 -maxdepth 5 -type f \( "${find_args[@]}" \) 2>/dev/null
}

backup_db() {
    log "Starting database backup"
    local failed=0

    # Each DB is backed up independently: a single failure is counted and
    # logged, never fatal, so one bad DB can't skip the remaining users'
    # backups (the pre-fix set -e behaviour silently torpedoed a whole run).
    if ! _backup_one_db "$DB" "{{ istota_namespace }}"; then
        failed=$((failed + 1))
    fi

    # Per-user module DBs (feeds, money, location, ...)
    local module_db user_id module
    while IFS= read -r module_db; do
        [ -z "$module_db" ] && continue
        # Path shape: {mount}/Users/<user>/<bot_dir>/<module>/data/<module>.db
        # Walk up from the file: dirname=data, parent=module, grandparent=bot_dir, then user.
        module=$(basename "$(dirname "$(dirname "$module_db")")")
        user_id=$(basename "$(dirname "$(dirname "$(dirname "$(dirname "$module_db")")")")")
        if ! _backup_one_db "$module_db" "${user_id}-${module}"; then
            failed=$((failed + 1))
        fi
    done < <(_discover_module_dbs)

    if [ "$failed" -gt 0 ]; then
        log "ERROR: Database backup completed with ${failed} failure(s)"
        _alert "$(hostname): database backup had ${failed} DB failure(s) — see zorg-backup.log"
        return 1
    fi

    log "Database backup complete"
    return 0
}

backup_files() {
    log "Starting files backup (rclone sync)"
    local failed=0

{% for source in istota_backup_files_sources %}
    log "Syncing ${RCLONE_REMOTE}:{{ source.src }} -> ${RCLONE_REMOTE}:${RCLONE_BACKUP_PATH}/{{ source.dest }}"
    # Each source is independent: a failed sync is counted, not fatal, so one
    # bad source can't skip the rest.
    if rclone sync \
        --config "$RCLONE_CONFIG" \
        "${RCLONE_REMOTE}:{{ source.src }}" \
        "${RCLONE_REMOTE}:${RCLONE_BACKUP_PATH}/{{ source.dest }}" \
{% for exclude in source.excludes | default([]) %}
        --exclude '{{ exclude }}' \
{% endfor %}
        --verbose \
        2>&1 | while IFS= read -r line; do log "  $line"; done; then
        log "Finished syncing {{ source.src }}"
    else
        log "ERROR: rclone sync failed for {{ source.src }}"
        failed=$((failed + 1))
    fi

{% endfor %}
    if [ "$failed" -gt 0 ]; then
        log "ERROR: Files backup completed with ${failed} sync failure(s)"
        _alert "$(hostname): files backup had ${failed} rclone sync failure(s) — see zorg-backup.log"
        return 1
    fi

    log "Files backup complete"
    return 0
}

# Aggregate exit status so a partial failure surfaces as a non-zero exit
# (visible in cron/journald) instead of a silent success.
rc=0
case "${1:-}" in
    db)
        backup_db || rc=1
        ;;
    files)
        backup_files || rc=1
        ;;
    all)
        backup_db || rc=1
        backup_files || rc=1
        ;;
    *)
        echo "Usage: $0 {db|files|all}" >&2
        exit 1
        ;;
esac
exit "$rc"
