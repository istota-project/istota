{# Per-user money secrets file. Path:
     /etc/{{ istota_namespace }}/secrets/{{ item.key }}/money.toml
   The seeded scheduler command sets MONEY_SECRETS_FILE to this path.

   Source of truth: the user's `[[resources]] type = "money"` entry in
   istota_users.<user>.resources. Recognized fields on that entry:
     - monarch_session_token   (only field actually required for sync)
     - monarch_email           (optional fallback for reauth)
     - monarch_password        (optional fallback for reauth) #}
{% set _money_resource = (item.value.resources | default([]))
       | selectattr('type', 'in', ['money', 'moneyman'])
       | list | first | default({}) %}
{% set _token = _money_resource.monarch_session_token | default('') %}
{% set _email = _money_resource.monarch_email | default('') %}
{% set _password = _money_resource.monarch_password | default('') %}
{% if _token or _email or _password %}
[monarch]
{% if _token %}
session_token = "{{ _token }}"
{% endif %}
{% if _email %}
email = "{{ _email }}"
{% endif %}
{% if _password %}
password = "{{ _password }}"
{% endif %}
{% endif %}
