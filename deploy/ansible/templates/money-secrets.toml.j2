{# Per-user money secrets file written to
   /etc/istota/secrets/{user_id}/moneyman.toml.
   Loaded by the in-process money skill via MONEYMAN_SECRETS_FILE. #}
{% set _money = item.value.money | default({}) %}
{% set _monarch = _money.monarch | default({}) %}
{% if _monarch %}
[monarch]
{% if _monarch.session_token | default('') %}
session_token = "{{ _monarch.session_token }}"
{% endif %}
{% if _monarch.email | default('') %}
email = "{{ _monarch.email }}"
{% endif %}
{% if _monarch.password | default('') %}
password = "{{ _monarch.password }}"
{% endif %}
{% endif %}
