#!/usr/bin/env bash
# {{ istota_namespace }}-run — run the {{ istota_package }} CLI on this host as the
# service user with the full daemon environment loaded.
#
# Managed by Ansible (templates/ns-run.sh.j2). Do not edit in place.
#
# Usage:
#   {{ istota_namespace }}-run repl -u stefan
#   {{ istota_namespace }}-run list
#   {{ istota_namespace }}-run task "..." -u stefan -x
#
# Any arguments are passed straight through to `{{ istota_package }} <args>`.
# Self-sudoes into the "{{ istota_user }}" service user, so the caller needs
# sudo rights (passwordless or interactive).
set -euo pipefail

SELF="/usr/local/bin/{{ istota_namespace }}-run"
SERVICE_USER="{{ istota_user }}"

# Re-exec as the service user if we aren't already it. sudo's default env_reset
# discards the caller's environment, which is what we want — we rebuild it below.
if [ "$(id -un)" != "$SERVICE_USER" ]; then
    exec sudo -u "$SERVICE_USER" -- "$SELF" "$@"
fi

export HOME="{{ istota_home }}"
export PATH="{{ istota_home }}/.venv/bin:$PATH"
export PYTHONUNBUFFERED=1

# Load the same secret bundle the systemd units use, if present. Absent when
# istota_use_environment_file=false (secrets are inlined into config.toml then,
# which the CLI reads directly), so this is best-effort.
SECRETS_ENV="/etc/{{ istota_namespace }}/secrets.env"
if [ -r "$SECRETS_ENV" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$SECRETS_ENV"
    set +a
fi

# Set by the systemd units via Environment=, not carried in secrets.env.
export ISTOTA_ADMINS_FILE="/etc/{{ istota_namespace }}/admins"

# cwd = repo dir so the CLI finds config/config.toml via the relative search
# path (same as the systemd units' WorkingDirectory).
cd "{{ istota_repo_dir }}"

# The `repl` subcommand defaults --workspace to cwd, which is now the install
# tree — a protected path the sandbox refuses to bind RW (it would let the bot
# shadow its own source). Default server repls to the per-user temp dir (the
# daemon's normal sandbox workspace) unless the caller chose a workspace.
args=("$@")
if [ "${1:-}" = "repl" ]; then
    has_workspace=0
    for a in "$@"; do
        case "$a" in
            --workspace|--workspace=*) has_workspace=1; break ;;
        esac
    done
    if [ "$has_workspace" -eq 0 ]; then
        args+=(--workspace standard)
    fi
fi

exec "{{ istota_home }}/.venv/bin/{{ istota_package }}" "${args[@]}"
