# Managed by Ansible — do not edit by hand.
# One devbox service per istota_devbox_users entry. The agent shells in via
# the host docker socket; nothing else talks to this stack.
#
# Explicit project name — without this, ``docker compose`` defaults the
# project to the parent directory name and pools containers across every
# compose file that lives in ``{{ istota_home }}``. ``ps -q`` against this
# file would then return browser / nextcloud / istota containers too and
# our "first deploy" check (which gates on an empty container list) would
# never fire.
name: {{ istota_namespace }}-devbox

services:
{% for devbox_user in istota_devbox_users %}
  {{ istota_devbox_container_prefix }}{{ devbox_user }}:
    image: {{ istota_devbox_image }}
    build:
      context: {{ istota_repo_dir }}/docker/devbox
      dockerfile: Dockerfile
    container_name: {{ istota_devbox_container_prefix }}{{ devbox_user }}
    hostname: {{ istota_devbox_container_prefix }}{{ devbox_user }}
    restart: unless-stopped
    labels:
      com.istota.user_id: "{{ devbox_user }}"
    cap_add:
      - NET_RAW
{% if istota_devbox_proxy_enabled and istota_devbox_proxy_group_gid is defined %}
    # Grant the container's `dev` user the host's istota group as a
    # supplementary group. The proxy socket is mode 0o660 owned by
    # istota:istota — without this group membership the container's uid
    # 1000 can't connect even though the socket is bind-mounted.
    group_add:
      - "{{ istota_devbox_proxy_group_gid }}"
{% endif %}
    volumes:
      - devbox_home_{{ devbox_user }}:/home/dev
{% if istota_devbox_proxy_enabled %}
      # Host-side credential proxy directory. We mount the per-user
      # directory (not the socket file) so daemon restarts can unlink
      # and recreate the socket inode without stranding the container
      # against a dead bind-mount target. Per-user subdir keeps cross-
      # tenant isolation — container alice sees only alice's socket.
      - {{ istota_devbox_proxy_socket_dir }}/{{ devbox_user }}:/run/istota-cred
{% endif %}
    tmpfs:
      - /workspace:size={{ istota_devbox_workspace_tmpfs_size }},mode=1777
    networks:
      - devbox-net
    mem_limit: {{ istota_devbox_mem_limit }}
    cpus: {{ istota_devbox_cpus }}
    pids_limit: {{ istota_devbox_pids_limit }}
    command: ["sleep", "infinity"]
{% endfor %}

volumes:
{% for devbox_user in istota_devbox_users %}
  devbox_home_{{ devbox_user }}:
    name: {{ istota_namespace }}-devbox-home-{{ devbox_user }}
{% endfor %}

networks:
  devbox-net:
    name: {{ istota_devbox_network_name }}
    driver: bridge
    internal: false
    ipam:
      config:
        - subnet: {{ istota_devbox_network_subnet }}
