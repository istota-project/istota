#!/usr/bin/env python3
"""GitHub REST API wrapper that talks through the devbox proxy.

Same CLI shape as ``gitlab-api`` — agents reach for either through
``$GITHUB_API_CMD`` / ``$GITLAB_API_CMD`` from the developer-skill prompt.
The token never enters the container; the daemon injects the
``Authorization: token …`` header server-side.
"""

from __future__ import annotations

import os
import sys

sys.path.insert(0, os.environ.get("ISTOTA_DEVBOX_LIB", "/usr/local/lib/istota_devbox"))
from istota_devbox_client import api_wrapper_main  # noqa: E402


if __name__ == "__main__":
    raise SystemExit(api_wrapper_main(sys.argv[1:], action="github_api", bin_name="github-api"))
