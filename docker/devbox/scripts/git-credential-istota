#!/usr/bin/env python3
"""git credential helper that proxies to the host-side devbox daemon.

Installed at /usr/local/bin/git-credential-istota inside the devbox
container. /etc/gitconfig wires it up via ``[credential] helper = istota``.

Invoked by git as ``git-credential-istota <op>`` with framed key=value
lines on stdin, where ``<op>`` is one of ``get``, ``store``, or ``erase``.
This shim packages the stdin into a JSON request, sends it to the host
daemon over a Unix socket, and writes the daemon's ``stdout`` payload
straight back to git.

For ``get``: always exit 0. Missing ``password=`` lines tell git "no
credential" — the right behaviour when the host has no token for the
target.

For ``store`` / ``erase``: no-op on the daemon side. We never persist
container-supplied credentials, and an in-container erase shouldn't be
able to invalidate the host's tokens.
"""

from __future__ import annotations

import os
import sys

# In the image the helper lives at /usr/local/lib/istota_devbox/. Tests
# point ISTOTA_DEVBOX_LIB at the repo's docker/devbox/lib so the same
# script works without docker.
sys.path.insert(0, os.environ.get("ISTOTA_DEVBOX_LIB", "/usr/local/lib/istota_devbox"))
from istota_devbox_client import (  # noqa: E402
    ProxyProtocolError,
    ProxyUnreachable,
    call,
    die,
)


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        die("usage: git-credential-istota <get|store|erase>", exit_code=2)
    op = argv[1]
    if op not in ("get", "store", "erase"):
        # Git only ever invokes the three documented ops; anything else
        # is a misconfiguration. Exit non-zero so git surfaces it.
        die(f"git-credential-istota: unknown op {op!r}", exit_code=2)

    stdin_payload = sys.stdin.read()

    try:
        response = call("git_credential", op=op, input=stdin_payload)
    except (ProxyUnreachable, ProxyProtocolError) as e:
        die(f"git-credential-istota: {e}", exit_code=1)

    if response.get("ok"):
        # `stdout` is git's framed credential output; write verbatim.
        out = response.get("stdout", "")
        if out:
            sys.stdout.write(out)
        return 0

    # Daemon returned a structured error. For `get` we still exit 0 with
    # empty stdout — git treats it as "no credential available".
    if op == "get":
        return 0
    # `store` / `erase` should never reach this branch since the daemon
    # acks both as ok, but be defensive.
    die(f"git-credential-istota: {response.get('message', 'proxy error')}", exit_code=1)
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
