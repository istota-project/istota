#!/usr/bin/env python3
"""GitLab REST API wrapper that talks through the devbox proxy.

Drop-in shape replacement for the host-side ``gitlab-api`` wrapper —
``--method``, ``--endpoint``, ``--body`` / ``--body-file`` /
``--body-stdin``, repeatable ``--header KEY=VALUE``. The token never
enters the container; the daemon injects ``PRIVATE-TOKEN`` server-side.
"""

from __future__ import annotations

import os
import sys

sys.path.insert(0, os.environ.get("ISTOTA_DEVBOX_LIB", "/usr/local/lib/istota_devbox"))
from istota_devbox_client import api_wrapper_main  # noqa: E402


if __name__ == "__main__":
    raise SystemExit(api_wrapper_main(sys.argv[1:], action="gitlab_api", bin_name="gitlab-api"))
