# Istota Docker deployment — environment variables
# Copy to .env and fill in values: cp .env.example .env

# =============================================================================
# Claude Code authentication (pick ONE)
# =============================================================================

# Option 1: OAuth token (from `claude setup-token` or ~/.claude/.credentials.json)
# This is the standard auth method for Claude Code subscriptions.
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: Direct API key (for API-key-based billing)
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Nextcloud accounts
# =============================================================================

# Nextcloud admin password
ADMIN_PASSWORD=changeme

# Your Nextcloud user account
USER_NAME=stefan
USER_PASSWORD=changeme

# Bot account password (internal, pick anything strong)
BOT_PASSWORD=changeme

# Postgres password (internal, pick anything strong)
POSTGRES_PASSWORD=changeme

# =============================================================================
# Optional
# =============================================================================

# Your display name in Nextcloud
USER_DISPLAY_NAME=Stefan

# Your timezone (IANA format)
USER_TIMEZONE=America/New_York

# Nextcloud port (default: 8080)
# NC_PORT=8080

# Domain name for production (leave empty for localhost)
# DOMAIN=istota.example.com
