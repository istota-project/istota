# =============================================================================
# Istota Docker Compose — Environment Variables
# Copy to .env and edit before running: docker compose up -d
#
# Optional services (activated via Docker Compose profiles):
#   docker compose --profile browser up -d    # Browser container
#   docker compose --profile location up -d   # GPS webhook receiver
#   docker compose --profile browser --profile location up -d  # Both
# =============================================================================

# --- Required ---

# Nextcloud admin password
ADMIN_PASSWORD=changeme

# Nextcloud database password
POSTGRES_PASSWORD=changeme

# Bot Nextcloud user password
BOT_PASSWORD=changeme

# Primary human user credentials
USER_NAME=alice
USER_PASSWORD=changeme

# Claude authentication (at least one required)
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# --- Nextcloud ---

# Nextcloud port on the host
NC_PORT=8080

# Trusted domains (space-separated, in addition to localhost and nextcloud)
DOMAIN=

# --- User profile ---

# Display name for the primary user
USER_DISPLAY_NAME=
# Timezone (IANA format)
USER_TIMEZONE=UTC
# Email address (enables email-related features)
USER_EMAIL=
# Talk room token for verbose execution logs
USER_LOG_CHANNEL=
# Per-user ntfy topic override
USER_NTFY_TOPIC=
# Per-user worker limits (0 = use global default)
USER_MAX_FOREGROUND_WORKERS=
USER_MAX_BACKGROUND_WORKERS=
# Per-user disabled skills (comma-separated, e.g. "browse,whisper")
USER_DISABLED_SKILLS=

# --- Bot identity ---

# User-facing bot name
ISTOTA_BOT_NAME=Istota
# Include constitutional principles in prompts
ISTOTA_EMISSARIES_ENABLED=true
# Claude model override (e.g. "sonnet", "opus"); empty = CLI default
ISTOTA_MODEL=
# Instance-wide disabled skills (comma-separated, e.g. "browse,whisper")
ISTOTA_DISABLED_SKILLS=
# Max total memory characters in prompts (0 = unlimited)
ISTOTA_MAX_MEMORY_CHARS=0


# --- Security ---

# Bubblewrap per-invocation filesystem sandbox (gracefully degrades if kernel disallows)
ISTOTA_SECURITY_SANDBOX_ENABLED=true
# Credential isolation via Unix socket proxy (strips secrets from Claude env)
ISTOTA_SECURITY_SKILL_PROXY_ENABLED=true
ISTOTA_SECURITY_SKILL_PROXY_TIMEOUT=300

# --- Talk ---

ISTOTA_TALK_ENABLED=true

# --- Email (optional) ---

ISTOTA_EMAIL_ENABLED=false
ISTOTA_EMAIL_IMAP_HOST=
ISTOTA_EMAIL_IMAP_PORT=993
ISTOTA_EMAIL_IMAP_USER=
ISTOTA_EMAIL_IMAP_PASSWORD=
ISTOTA_EMAIL_SMTP_HOST=
ISTOTA_EMAIL_SMTP_PORT=587
ISTOTA_EMAIL_POLL_FOLDER=INBOX
ISTOTA_EMAIL_BOT_ADDRESS=

# --- Scheduler — polling intervals ---

ISTOTA_SCHEDULER_POLL_INTERVAL=5
ISTOTA_SCHEDULER_TALK_POLL_INTERVAL=10
ISTOTA_SCHEDULER_TALK_POLL_TIMEOUT=30
ISTOTA_SCHEDULER_TALK_POLL_WAIT=2.0
ISTOTA_SCHEDULER_EMAIL_POLL_INTERVAL=60
ISTOTA_SCHEDULER_BRIEFING_CHECK_INTERVAL=60
ISTOTA_SCHEDULER_TASKS_FILE_POLL_INTERVAL=30
ISTOTA_SCHEDULER_SHARED_FILE_CHECK_INTERVAL=120
ISTOTA_SCHEDULER_HEARTBEAT_CHECK_INTERVAL=60

# --- Scheduler — progress updates (Talk only) ---

ISTOTA_SCHEDULER_PROGRESS_UPDATES=true
ISTOTA_SCHEDULER_PROGRESS_MIN_INTERVAL=8
ISTOTA_SCHEDULER_PROGRESS_MAX_MESSAGES=5
ISTOTA_SCHEDULER_PROGRESS_SHOW_TOOL_USE=true
ISTOTA_SCHEDULER_PROGRESS_SHOW_TEXT=false
ISTOTA_SCHEDULER_PROGRESS_TEXT_MAX_CHARS=200
# "replace" (edit ack in-place), "full" (append all), "none" (silent)
ISTOTA_SCHEDULER_PROGRESS_STYLE=replace
ISTOTA_SCHEDULER_PROGRESS_MAX_DISPLAY_ITEMS=20

# --- Scheduler — robustness & cleanup ---

ISTOTA_SCHEDULER_TASK_TIMEOUT_MINUTES=30
ISTOTA_SCHEDULER_CONFIRMATION_TIMEOUT_MINUTES=120
ISTOTA_SCHEDULER_STALE_PENDING_WARN_MINUTES=30
ISTOTA_SCHEDULER_STALE_PENDING_FAIL_HOURS=2
ISTOTA_SCHEDULER_MAX_RETRY_AGE_MINUTES=60
ISTOTA_SCHEDULER_TASK_RETENTION_DAYS=7
ISTOTA_SCHEDULER_EMAIL_RETENTION_DAYS=7
ISTOTA_SCHEDULER_WORKER_IDLE_TIMEOUT=30
ISTOTA_SCHEDULER_MAX_FOREGROUND_WORKERS=3
ISTOTA_SCHEDULER_MAX_BACKGROUND_WORKERS=2
ISTOTA_SCHEDULER_USER_MAX_FOREGROUND_WORKERS=2
ISTOTA_SCHEDULER_USER_MAX_BACKGROUND_WORKERS=1
ISTOTA_SCHEDULER_SCHEDULED_JOB_MAX_CONSECUTIVE_FAILURES=5
ISTOTA_SCHEDULER_FEED_CHECK_INTERVAL=300
ISTOTA_SCHEDULER_FEED_ITEM_RETENTION_DAYS=30
ISTOTA_SCHEDULER_TALK_CACHE_MAX_PER_CONVERSATION=200
ISTOTA_SCHEDULER_TEMP_FILE_RETENTION_DAYS=7
ISTOTA_SCHEDULER_LOCATION_PING_RETENTION_DAYS=365

# --- Conversation context ---

ISTOTA_CONVERSATION_ENABLED=true
ISTOTA_CONVERSATION_LOOKBACK_COUNT=25
ISTOTA_CONVERSATION_SELECTION_MODEL=haiku
ISTOTA_CONVERSATION_SELECTION_TIMEOUT=30.0
ISTOTA_CONVERSATION_SKIP_SELECTION_THRESHOLD=3
ISTOTA_CONVERSATION_USE_SELECTION=true
ISTOTA_CONVERSATION_ALWAYS_INCLUDE_RECENT=5
ISTOTA_CONVERSATION_CONTEXT_TRUNCATION=0
ISTOTA_CONVERSATION_CONTEXT_RECENCY_HOURS=0
ISTOTA_CONVERSATION_CONTEXT_MIN_MESSAGES=10
ISTOTA_CONVERSATION_PREVIOUS_TASKS_COUNT=3
ISTOTA_CONVERSATION_TALK_CONTEXT_LIMIT=100

# --- Logging ---

ISTOTA_LOGGING_LEVEL=INFO
# "console", "file", or "both"
ISTOTA_LOGGING_OUTPUT=console
ISTOTA_LOGGING_FILE=

# --- Sleep cycle (nightly memory extraction) ---

ISTOTA_SLEEP_CYCLE_ENABLED=true
ISTOTA_SLEEP_CYCLE_CRON=0 2 * * *
ISTOTA_SLEEP_CYCLE_LOOKBACK_HOURS=24
ISTOTA_SLEEP_CYCLE_MEMORY_RETENTION_DAYS=0
ISTOTA_SLEEP_CYCLE_AUTO_LOAD_DATED_DAYS=3
ISTOTA_SLEEP_CYCLE_CURATE_USER_MEMORY=false

# --- Channel sleep cycle ---

ISTOTA_CHANNEL_SLEEP_CYCLE_ENABLED=true
ISTOTA_CHANNEL_SLEEP_CYCLE_CRON=0 3 * * *
ISTOTA_CHANNEL_SLEEP_CYCLE_LOOKBACK_HOURS=24
ISTOTA_CHANNEL_SLEEP_CYCLE_MEMORY_RETENTION_DAYS=0

# --- Memory search ---

ISTOTA_MEMORY_SEARCH_ENABLED=false
ISTOTA_MEMORY_SEARCH_AUTO_INDEX_CONVERSATIONS=true
ISTOTA_MEMORY_SEARCH_AUTO_INDEX_MEMORY_FILES=true
ISTOTA_MEMORY_SEARCH_AUTO_RECALL=false
ISTOTA_MEMORY_SEARCH_AUTO_RECALL_LIMIT=5

# --- ntfy notifications (optional) ---

ISTOTA_NTFY_ENABLED=false
ISTOTA_NTFY_SERVER_URL=https://ntfy.sh
ISTOTA_NTFY_TOPIC=
# Token auth (preferred)
ISTOTA_NTFY_TOKEN=
# Basic auth (alternative)
ISTOTA_NTFY_USERNAME=
ISTOTA_NTFY_PASSWORD=
ISTOTA_NTFY_PRIORITY=3

# --- Browser container (optional, activate with: --profile browser) ---

ISTOTA_BROWSER_ENABLED=false
# API URL as seen by the istota container (use container name for Docker networking)
ISTOTA_BROWSER_API_URL=http://istota-browser:9223
ISTOTA_BROWSER_VNC_URL=
VNC_PASSWORD=
# Container resource settings
BROWSER_API_BIND=127.0.0.1
BROWSER_API_PORT=9223
BROWSER_VNC_PORT=6080
BROWSER_SHM_SIZE=2gb
BROWSER_MEMORY_LIMIT=3G

# --- Location tracking (optional, activate with: --profile location) ---

ISTOTA_LOCATION_ENABLED=false
ISTOTA_WEBHOOKS_PORT=8765

# --- Developer skill (optional) ---

ISTOTA_DEVELOPER_ENABLED=false
ISTOTA_DEVELOPER_REPOS_DIR=
ISTOTA_DEVELOPER_AUTHOR_CREDIT=
# GitLab
ISTOTA_DEVELOPER_GITLAB_URL=https://gitlab.com
ISTOTA_DEVELOPER_GITLAB_TOKEN=
ISTOTA_DEVELOPER_GITLAB_USERNAME=
ISTOTA_DEVELOPER_GITLAB_DEFAULT_NAMESPACE=
ISTOTA_DEVELOPER_GITLAB_REVIEWER_ID=
# GitHub
ISTOTA_DEVELOPER_GITHUB_URL=https://github.com
ISTOTA_DEVELOPER_GITHUB_TOKEN=
ISTOTA_DEVELOPER_GITHUB_USERNAME=
ISTOTA_DEVELOPER_GITHUB_DEFAULT_OWNER=
ISTOTA_DEVELOPER_GITHUB_REVIEWER=

# --- Briefing defaults (optional) ---

# News lookback hours for briefings
ISTOTA_BRIEFING_DEFAULTS_NEWS_LOOKBACK_HOURS=
# News sources — for complex values, edit config.toml directly after first run
ISTOTA_BRIEFING_DEFAULTS_NEWS_SOURCES=
